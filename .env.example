# Database connection (required)
DATABASE_URL=postgres://user:password@localhost:5432/var_codemap

# Or use individual variables:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=your_user
# PGPASSWORD=your_password
# PGDATABASE=var_codemap

# Google Gemini API key (required for `annotate` command)
GEMINI_API_KEY=your_gemini_api_key

# OpenAI API key (required for `query` command)
OPENAI_API_KEY=your_openai_api_key
